{
  "manifest_version": 3,
  "name": "MSCI AEM Publisher",
  "version": "1.0.0",
  "description": "Bridge between MSCI Publishing Platform and AEM Author",
  "permissions": [
    "sidePanel",
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://author-p125318-e1369672.adobeaemcloud.com/*"
  ],
  "action": {
    "default_title": "MSCI AEM Publisher"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
