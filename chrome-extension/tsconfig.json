{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": false,
    "skipLibCheck": true,
    "noEmit": false,
    "types": ["chrome"]
  },
  "include": [
    "background/**/*.ts",
    "sidepanel/**/*.ts"
  ],
  "exclude": ["node_modules", "devtools"]
}
